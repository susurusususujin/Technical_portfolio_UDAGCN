@torch.no_grad()
def eval_joint_micro(
    H, edge_index, edge_type, head, node_domain, nodes_by_domain, restrict_pairs,
    neg_ratio_eval=JOINT_NEG_RATIO_EVAL, sample_limit=8192, device=None, batch=4096, n_thr=101
):
    if device is None: device = H.device
    edge_index = edge_index.to(device=device, dtype=torch.long).contiguous()
    edge_type  = edge_type.to(device=device, dtype=torch.long).contiguous()
    nd         = node_domain.to(device=device, dtype=torch.long)
    Eh = edge_index.size(1)//2
    if Eh == 0:
        return {"thr_best": 0.5, "f1_best": torch.tensor(0.0, device=device),
                "acc_best": torch.tensor(0.0, device=device), "n_pos": 0, "n_neg": 0}

    uv_pos = edge_index[:, :Eh]
    ds, dt = nd[uv_pos[0]], nd[uv_pos[1]]
    mask = torch.zeros(Eh, dtype=torch.bool, device=device)
    for (a,b) in restrict_pairs: mask |= ((ds==a)&(dt==b))
    uv_pos = uv_pos[:, mask]; P = int(uv_pos.size(1))
    if P == 0:
        return {"thr_best": 0.5, "f1_best": torch.tensor(0.0, device=device),
                "acc_best": torch.tensor(0.0, device=device), "n_pos": 0, "n_neg": 0}

    if sample_limit and P > sample_limit:
        idx = torch.randperm(P, device=device)[:sample_limit]
        uv_pos = uv_pos[:, idx]; P = int(uv_pos.size(1))

    neg_uv = sample_neg_pairs(uv_pos, node_domain, nodes_by_domain, k=int(neg_ratio_eval), device=device)
    N = int(neg_uv.size(1)) if neg_uv is not None else 0

    head.eval()
    def _p_link_for_pairs(uv):
        if uv is None or uv.numel()==0: return torch.empty(0, device=device)
        scores=[]
        for st in range(0, uv.size(1), batch):
            ed = min(st+batch, uv.size(1))
            logits = head(H[uv[0,st:ed]], H[uv[1,st:ed]])
            prob = F.softmax(logits, dim=-1)
            scores.append(1.0 - prob[:,0])
        return torch.cat(scores, dim=0)

    s_pos = _p_link_for_pairs(uv_pos)
    s_neg = _p_link_for_pairs(neg_uv)
    if s_pos.numel()==0 or s_neg.numel()==0:
        return {"thr_best": 0.5, "f1_best": torch.tensor(0.0, device=device),
                "acc_best": torch.tensor(0.0, device=device), "n_pos": int(s_pos.numel()), "n_neg": int(s_neg.numel())}

    y_pos = torch.ones_like(s_pos, dtype=torch.long, device=device)
    y_neg = torch.zeros_like(s_neg, dtype=torch.long, device=device)
    scores = torch.cat([s_pos, s_neg], dim=0); labels = torch.cat([y_pos, y_neg], dim=0)

    best_thr, best_f1, best_acc = 0.5, -1.0, 0.0
    for t in torch.linspace(0.0, 1.0, steps=n_thr, device=device):
        pred = (scores >= t).long()
        tp = (pred.eq(1)&labels.eq(1)).sum().item()
        fp = (pred.eq(1)&labels.eq(0)).sum().item()
        fn = (pred.eq(0)&labels.eq(1)).sum().item()
        tn = (pred.eq(0)&labels.eq(0)).sum().item()
        prec = tp/max(1,tp+fp); rec = tp/max(1,tp+fn)
        f1 = (2*prec*rec/max(1e-12,(prec+rec))) if (prec+rec)>0 else 0.0
        acc = (tp+tn)/max(1,tp+tn+fp+fn)
        if f1 > best_f1:
            best_f1, best_thr, best_acc = f1, float(t.item()), acc

    return {"thr_best": best_thr, "f1_best": torch.tensor(best_f1, device=device),
            "acc_best": torch.tensor(best_acc, device=device), "n_pos": P, "n_neg": N}

