# 도메인/역할 매핑 및 라벨 파서
DOMAIN_MAP = {"ai":0, "MB":1, "mb":1, "AE":2, "ae":2}
ROLE_MAP   = {"problem":0, "solution":1}

# 다양한 구분자 지원 ( ; / | , _ 공백 & : - )
_SPLIT_RE = re.compile(r"[;/|,_\s&:\-]+")

def parse_domain_role_from_labels(label):
    """
    label 이 문자열/리스트 어느 형태든 robust하게 파싱.
    한 노드에서 여러 도메인이 검출되면 우선순위 하나만 선택:
      Manufacturing(3) > Biology(2) > AI(1)
    """
    dom = -1; role = -1
    if label is None:
        return dom, role

    # 1) 문자열 리스트로 평탄화
    raw_tokens = []
    if isinstance(label, str):
        raw_tokens = [label]
    elif isinstance(label, (list, tuple)):
        for x in label:
            if x is None: continue
            raw_tokens.append(x if isinstance(x, str) else str(x))
    else:
        raw_tokens = [str(label)]

    # 2) 토큰화/정규화
    toks = []
    for s in raw_tokens:
        for t in _SPLIT_RE.split(s):
            t = t.strip().lower()
            if t: toks.append(t)
    seen = set(); toks_unique = []
    for t in toks:
        if t not in seen:
            toks_unique.append(t); seen.add(t)

    # 역할
    for t in toks_unique:
        if t in ROLE_MAP and role < 0:
            role = ROLE_MAP[t]

    # 도메인 우선순위
    prio = {"MB":3, "mb":3, "AE":2, "ae":2, "ai":1}
    best = (-1, 0)  # (dom_id, priority)
    for t in toks_unique:
        if t in DOMAIN_MAP:
            cand = (DOMAIN_MAP[t], prio.get(t, 0))
            if cand[1] > best[1]:
                best = cand
    dom = best[0]
    return dom, role

def _parse_identity_from_elementId(elementId: str):
    try:
        return int(str(elementId).split(":")[-1])
    except Exception:
        return None

def load_graph_json(path: str):
    with open(path, "r", encoding="utf-8-sig") as f:
        s = f.read().strip()
    if not s: raise ValueError(f"Empty JSON: {path}")
    try:
        obj = json.loads(s)
    except json.JSONDecodeError:
        lines = [ln.strip() for ln in s.splitlines() if ln.strip()]
        obj = [json.loads(ln) for ln in lines]

    def is_row(x): return isinstance(x, dict) and ("n" in x and "r" in x and "m" in x)

    nodes, edges = [], []
    if isinstance(obj, list) and len(obj)>0 and is_row(obj[0]):
        # Triplet 스타일
        node_map = {}
        def pick_name(nd):
            props = nd.get("properties", {}) or {}
            return props.get("name") or props.get("title") or props.get("label") or str(nd.get("identity","")) or nd.get("elementId","")
        for row in obj:
            n = row.get("n", {}); m = row.get("m", {}); r = row.get("r", {})
            for nd in (n, m):
                nid = nd.get("identity", nd.get("elementId", None))
                if nid is None: continue
                # 문자열화(나중에 id2idx 키로 사용)
                nid_str = str(nid)

                raw_labels = nd.get("labels", [])
                if not raw_labels:
                    raw_labels = nd.get("label") or nd.get("type") or ""
                dom, role = parse_domain_role_from_labels(raw_labels)

                if nid_str not in node_map:
                    node_map[nid_str] = {
                        "id": nid_str,
                        "name": pick_name(nd),
                        "labels": raw_labels,   # 원본 라벨 보존
                        "domain": dom,
                        "role": role
                    }
                else:
                    if node_map[nid_str]["domain"] < 0 and dom >= 0: node_map[nid_str]["domain"] = dom
                    if node_map[nid_str]["role"]   < 0 and role>= 0: node_map[nid_str]["role"]   = role

            start = r.get("start"); end = r.get("end"); rtype = r.get("type", "rel")
            if start is not None and end is not None:
                edges.append((str(start), str(end), str(rtype)))
        nodes = list(node_map.values())
    else:
        # 자유형 JSON
        def is_edge_dict(d):
            return isinstance(d, dict) and any(k in d for k in ("source","start","src")) and any(k in d for k in ("target","end","dst"))
        def is_node_dict(d):
            return isinstance(d, dict) and any(k in d for k in ("id","name","label","labels","type","domain","role"))
        def walk(x):
            if isinstance(x, dict):
                if is_edge_dict(x): edges.append(x)
                elif is_node_dict(x): nodes.append(x)
                for v in x.values(): walk(v)
            elif isinstance(x, (list, tuple)):
                for v in x: walk(v)
        walk(obj)
        def get_src(d): return d.get("source", d.get("start", d.get("src")))
        def get_dst(d): return d.get("target", d.get("end",   d.get("dst")))
        if not nodes and edges:
            tmp = {}
            for e in edges:
                for nid in (get_src(e), get_dst(e)):
                    if nid is None: continue
                    tmp[str(nid)] = {"id": str(nid)}
            nodes = list(tmp.values())
        E2 = []
        for e in edges:
            src = e.get("source", e.get("start", e.get("src")))
            dst = e.get("target", e.get("end",   e.get("dst")))
            rname = e.get("type", e.get("label", e.get("relation","rel")))
            if src is None or dst is None: continue
            E2.append((str(src), str(dst), str(rname)))
        edges = E2

    # 인덱싱
    node_ids = []
    for e in nodes:
        nid = e.get("id", e.get("name"))
        if nid is not None: node_ids.append(str(nid))
    for (u,v,_) in edges:
        node_ids += [u, v]
    node_ids = list(dict.fromkeys(node_ids))
    id2idx = {nid:i for i, nid in enumerate(node_ids)}
    N = len(id2idx)

    # 원본 identity 리스트(idx → 원본 id)
    idx2orig_id = []
    for nid in node_ids:
        # nid가 숫자 문자열이면 int 변환, 아니라면 elementId에서 마지막 토큰 시도
        try:
            idx2orig_id.append(int(nid))
        except:
            idx2orig_id.append(_parse_identity_from_elementId(nid))

    node_domain = torch.full((N,), -1, dtype=torch.long)
    node_role   = torch.full((N,), -1, dtype=torch.long)
    names = [""]*N
    labels_raw_per_idx = [None]*N  # 원본 라벨 보존

    for e in nodes:
        nid = e.get("id", e.get("name"))
        if nid is None: continue
        i = id2idx[str(nid)]
        names[i] = e.get("name", str(nid))

        raw_labels = e.get("labels", []) or e.get("label") or e.get("type") or ""
        labels_raw_per_idx[i] = raw_labels

        dom = e.get("domain", -1); role = e.get("role", -1)
        if dom < 0 or role < 0:
            d2, r2 = parse_domain_role_from_labels(raw_labels)
            if dom  < 0 and d2>=0: dom  = d2
            if role < 0 and r2>=0: role = r2
        node_domain[i] = dom; node_role[i] = role

    # 관계 id 매핑
    rel2id = {}
    for _,_,r in edges:
        if r not in rel2id: rel2id[r] = len(rel2id)
    num_rel = len(rel2id)

    # 양방향 edge_index / edge_type
    f_src, f_dst, f_type = [], [], []
    b_src, b_dst, b_type = [], [], []
    for (u_id, v_id, rname) in edges:
        if u_id not in id2idx or v_id not in id2idx: continue
        u = id2idx[u_id]; v = id2idx[v_id]; rid = rel2id[rname]
        f_src.append(u); f_dst.append(v); f_type.append(rid)
        b_src.append(v); b_dst.append(u); b_type.append(rid + num_rel)

    edge_index = torch.tensor([f_src + b_src, f_dst + b_dst], dtype=torch.long) if (f_src or b_src) else torch.zeros((2,0), dtype=torch.long)
    edge_type  = torch.tensor(f_type + b_type, dtype=torch.long) if (f_type or b_type) else torch.zeros((0,), dtype=torch.long)

    data = SimpleNamespace(
        num_nodes=len(id2idx),
        names=names,
        edge_index=edge_index,
        edge_type=edge_type,
        node_domain=node_domain,
        node_role=node_role,
        num_rel=num_rel,
        labels_raw=labels_raw_per_idx,  # 감사/검증용
        idx2orig_id=idx2orig_id        # ✅ 내부 idx → 원본 identity
    )
    meta = SimpleNamespace(rel2id=rel2id)
    print(f"[Loader] nodes={data.num_nodes}, edges(undirected)={edge_index.size(1)//2}, #rel={num_rel}")
    return data, meta

def build_subgraph(data, keep_domains: set):
    dom = data.node_domain
    N = data.num_nodes
    keep = torch.tensor([ (d.item() in keep_domains) for d in dom ], dtype=torch.bool)
    old2new = -torch.ones(N, dtype=torch.long)
    kept_idx = torch.nonzero(keep, as_tuple=False).view(-1)
    for new_i, old_i in enumerate(kept_idx.tolist()):
        old2new[old_i] = new_i
    newN = kept_idx.numel()

    E = data.edge_index.size(1); Eh = E//2
    ei_f = data.edge_index[:, :Eh]; et_f = data.edge_type[:Eh]
    ei_b = data.edge_index[:, Eh:]; et_b = data.edge_type[Eh:]

    def filt(ei, et):
        s, t = ei[0], ei[1]
        m = keep[s] & keep[t]
        s2 = old2new[s[m]]; t2 = old2new[t[m]]
        et2 = et[m]
        return torch.stack([s2, t2], dim=0), et2

    ei_f2, et_f2 = filt(ei_f, et_f); ei_b2, et_b2 = filt(ei_b, et_b)
    edge_index = torch.cat([ei_f2, ei_b2], dim=1)
    edge_type  = torch.cat([et_f2, et_b2], dim=0)

    # ✅ labels_raw / names / idx2orig_id 전달
    labels_raw = [data.labels_raw[i] for i in kept_idx.tolist()] if hasattr(data, "labels_raw") and data.labels_raw is not None else None
    names      = [data.names[i] for i in kept_idx.tolist()] if hasattr(data, "names") and data.names is not None else None
    idx2orig   = [data.idx2orig_id[i] for i in kept_idx.tolist()] if hasattr(data, "idx2orig_id") and data.idx2orig_id is not None else None

    return SimpleNamespace(
        num_nodes=newN,
        edge_index=edge_index,
        edge_type=edge_type,
        node_domain=data.node_domain[keep],
        node_role=data.node_role[keep],
        num_rel=data.num_rel,
        labels_raw=labels_raw,
        names=names,
        idx2orig_id=idx2orig
    )

def filter_edges_by_domain_pairs(edge_index, node_domain: torch.Tensor, keep_pairs: set):
    s, t = edge_index[0], edge_index[1]
    if node_domain.device != s.device:
        node_domain = node_domain.to(s.device)
    ds, dt = node_domain[s], node_domain[t]
    m = torch.zeros(s.size(0), dtype=torch.bool, device=s.device)
    for (a, b) in keep_pairs:
        m |= ((ds == a) & (dt == b))
    return m

from model.compgcn_conv import CompGCNConv  # 원본 CompGCN 레이어 사용

class CompRGCNEncoder(nn.Module):
    def __init__(self, num_ent, num_rel, init_dim=64, gcn_dim=128, embed_dim=64,
                 dropout=0.1, opn='corr', bias=True, gcn_layers=2):
        super().__init__()
        self.num_ent = num_ent
        self.num_rel = num_rel
        self.init_emb = nn.Parameter(torch.randn(num_ent, init_dim))
        self.init_rel = nn.Parameter(torch.randn(num_rel * 2, init_dim))  # 양방향
        self.p = SimpleNamespace(
            dropout=dropout, opn=opn, bias=bias, num_bases=0, gcn_layer=gcn_layers,
            embed_dim=embed_dim, init_dim=init_dim, gcn_dim=gcn_dim, num_ent=num_ent, num_rel=num_rel
        )
        self.conv1 = CompGCNConv(init_dim, gcn_dim, num_rel, act=torch.tanh, params=self.p)
        self.drop1 = nn.Dropout(dropout)
        self.conv2 = CompGCNConv(gcn_dim, embed_dim, num_rel, act=torch.tanh, params=self.p) if gcn_layers==2 else None
        self.drop2 = nn.Dropout(dropout)
        self.register_parameter('bias', Parameter(torch.zeros(num_ent)))

    def forward(self, edge_index, edge_type):
        x = self.init_emb
        x, r = self.conv1(x, edge_index, edge_type, rel_embed=self.init_rel)
        x = self.drop1(x)
        if self.conv2 is not None:
            x, r = self.conv2(x, edge_index, edge_type, rel_embed=r)
            x = self.drop2(x)
        return x

class GradReverse(torch.autograd.Function):
    @staticmethod
    def forward(ctx, x, lambd): ctx.lambd = lambd; return x.view_as(x)
    @staticmethod
    def backward(ctx, g): return g.neg() * ctx.lambd, None

class GRL(nn.Module):
    def __init__(self): super().__init__(); self._l=0.0
    def set_lambda(self, l: float): self._l = float(l)
    def forward(self, x): return GradReverse.apply(x, self._l)

class PairClassifier(nn.Module):
    def __init__(self, d, hidden=128, num_classes=2):
        super().__init__()
        self.fc = nn.Sequential(
            nn.Linear(d*4, hidden), nn.ReLU(), nn.Dropout(0.1),
            nn.Linear(hidden, num_classes)
        )
    def forward(self, hu, hv):
        z = torch.cat([hu, hv, (hu-hv).abs(), hu*hv], dim=-1)
        return self.fc(z)

def sample_pos_neg_edges(edge_index, num_nodes, num_neg=None, device=None):
    if device is None: device = edge_index.device
    E = edge_index.size(1); Eh = E//2
    if Eh == 0: return None, None
    pos = edge_index[:, :Eh]
    if num_neg is None: num_neg = Eh
    idx = torch.randint(0, Eh, (num_neg,), device=device)
    neg_src = pos[0, idx]
    neg_dst = torch.randint(0, num_nodes, (num_neg,), device=device)
    neg = torch.stack([neg_src, neg_dst], dim=0)
    return pos, neg

def sample_neg_domain_matched(pos, node_domain: torch.Tensor, nodes_by_domain: dict,
                              k: int, max_negs: int, device):
    if pos is None or pos.size(1) == 0:
        return None
    P = pos.size(1)
    num_neg = min(int(P * max(1,k)), max_negs)
    k_eff = max(1, num_neg // P)

    pos = pos.to(device)
    node_domain = node_domain.to(device)
    src_rep = pos[0].repeat_interleave(k_eff)
    desired_t_dom = node_domain[pos[1]].repeat_interleave(k_eff)

    neg_dst = torch.empty_like(src_rep)
    for d, pool in nodes_by_domain.items():
        pool = pool.to(device)
        mask = (desired_t_dom == d)
        m = int(mask.sum().item())
        if m > 0:
            idx = torch.randint(0, pool.size(0), (m,), device=device)
            neg_dst[mask] = pool[idx]
    return torch.stack([src_rep, neg_dst], dim=0)

@torch.no_grad()
def build_adj_sets(edge_index, num_nodes):
    Eh = edge_index.size(1)//2
    pos = edge_index[:, :Eh].cpu()
    adj = [set() for _ in range(num_nodes)]
    for u, v in zip(pos[0].tolist(), pos[1].tolist()):
        adj[u].add(v)
    return adj

@torch.no_grad()
def eval_link_metrics(H, edge_index, head: nn.Module,
                      restrict_pairs: set=None, node_domain: torch.Tensor=None,
                      sample_limit: int = 4096,
                      nodes_by_domain: dict=None,
                      domain_matched_neg: bool=True,
                      return_best: bool=True):
    """
    분류 지표: ACC(0.5), balACC, AUC + (옵션) ACC@best, thr_best
    평가 음성도 도메인 일치로 샘플(domain_matched_neg=True) 가능.
    """
    device = H.device
    E = edge_index.size(1); Eh = E // 2
    if Eh == 0:
        z = torch.tensor(0.0, device=device)
        out = {"bal_acc": z, "acc": z, "auc": torch.tensor(0.5, device=device)}
        if return_best: out.update({"acc_best": z, "thr_best": 0.5})
        return out

    pos = edge_index[:, :Eh].to(device)
    if restrict_pairs is not None and node_domain is not None:
        m = filter_edges_by_domain_pairs(pos, node_domain, restrict_pairs)
        pos = pos[:, m]
        if pos.numel() == 0:
            z = torch.tensor(0.0, device=device)
            out = {"bal_acc": z, "acc": z, "auc": torch.tensor(0.5, device=device)}
            if return_best: out.update({"acc_best": z, "thr_best": 0.5})
            return out

    P = pos.size(1)
    if P > sample_limit:
        idx = torch.randperm(P, device=device)[:sample_limit]
        pos = pos[:, idx]; P = pos.size(1)

    # --- 음성: 도메인 매칭(양성 tail과 같은 도메인에서 샘플) ---
    if domain_matched_neg and (nodes_by_domain is not None) and (node_domain is not None):
        ds = node_domain[pos[1]].to(device)  # 각 양성의 tail 도메인
        neg_t = torch.empty_like(ds)
        for d in ds.unique().tolist():
            mask = (ds == d)
            pool = nodes_by_domain.get(int(d), None)
            if pool is None or pool.numel() == 0:
                neg_t[mask] = torch.randint(0, H.size(0), (int(mask.sum().item()),), device=device)
            else:
                pool = pool.to(device)
                ridx = torch.randint(0, pool.size(0), (int(mask.sum().item()),), device=device)
                neg_t[mask] = pool[ridx]
        neg = torch.stack([pos[0], neg_t], dim=0)
    else:
        idx_rand = torch.randint(0, H.size(0), (P,), device=device)
        neg = torch.stack([pos[0], idx_rand], dim=0)

    # 점수
    s_pos = F.softmax(head(H[pos[0]], H[pos[1]]), dim=-1)[:, 1]
    s_neg = F.softmax(head(H[neg[0]], H[neg[1]]), dim=-1)[:, 1]

    # ACC(0.5) + balACC
    acc_pos = (s_pos >= 0.5).float().mean()
    acc_neg = (s_neg < 0.5).float().mean()
    bal_acc = (acc_pos + acc_neg) / 2
    acc = torch.cat([(s_pos >= 0.5).float(), (s_neg < 0.5).float()], dim=0).mean()

    # AUC(순위 근사)
    scores = torch.cat([s_pos, s_neg], dim=0)
    labels = torch.cat([torch.ones_like(s_pos), torch.zeros_like(s_neg)], dim=0)
    sorted_scores, order = torch.sort(scores)
    ranks = torch.empty_like(order, dtype=torch.float); ranks[order] = torch.arange(1, scores.numel()+1, device=device, dtype=torch.float)
    pos_ranks = ranks[labels == 1]
    auc = (pos_ranks.sum() - (s_pos.numel() * (s_pos.numel() + 1) / 2)) / (s_pos.numel() * s_neg.numel() + 1e-12)

    out = {"bal_acc": bal_acc, "acc": acc, "auc": auc}

    # --- 최적 임계값 ACC ---
    if return_best:
        thr_grid = torch.linspace(0.05, 0.95, steps=19, device=device)
        accs = []
        for th in thr_grid:
            acc_pos_th = (s_pos >= th).float().mean()
            acc_neg_th = (s_neg <  th).float().mean()
            accs.append((acc_pos_th + acc_neg_th)/2)
        accs = torch.stack(accs)
        best_idx = torch.argmax(accs)
        out["acc_best"] = accs[best_idx]
        out["thr_best"] = float(thr_grid[best_idx].item())

    return out

@torch.no_grad()
def eval_ranking_metrics(H, edge_index, head: nn.Module, node_domain: torch.Tensor,
                         restrict_pairs: set, nodes_by_domain: dict, adj_sets: list,
                         sample_queries: int = 1000, filtered: bool = True,
                         batch_size: int = 4096):
    """
    후보군: tail 도메인 일치
    필터드: u의 다른 실제 이웃 제거 (v_true 제외)
    반환: H@10
    """
    device = H.device
    Eh = edge_index.size(1)//2
    if Eh == 0:
        z = torch.tensor(0.0, device=device)
        return {"hits@10": z}
    pos = edge_index[:, :Eh].to(device)
    m = filter_edges_by_domain_pairs(pos, node_domain, restrict_pairs)
    pos = pos[:, m]
    P = pos.size(1)
    if P == 0:
        z = torch.tensor(0.0, device=device)
        return {"hits@10": z}
    if P > sample_queries:
        idx = torch.randperm(P, device=device)[:sample_queries]
        pos = pos[:, idx]; P = pos.size(1)

    hit10 = 0
    for j in range(P):
        u = pos[0, j].item()
        v_true = pos[1, j].item()
        dt = int(node_domain[v_true].item())
        cands = nodes_by_domain.get(dt, None)
        if cands is None or cands.numel() == 0:
            continue
        cands = cands.to(device)
        # 필터드 랭킹
        if filtered and len(adj_sets[u]) > 0:
            bad = torch.tensor([v for v in adj_sets[u] if v != v_true], device=device, dtype=torch.long)
            if bad.numel() > 0:
                keep_mask = torch.ones(cands.size(0), dtype=torch.bool, device=device)
                keep_mask[torch.isin(cands, bad)] = False
                keep_mask = keep_mask | (cands == v_true)
                cands = cands[keep_mask]
                if cands.numel() == 0:  # 모두 제거되면 스킵
                    continue
        # 스코어 & 랭크
        hu = H[u].unsqueeze(0).expand(cands.size(0), -1)
        scores = []
        for st in range(0, cands.size(0), batch_size):
            ed = min(st+batch_size, cands.size(0))
            s_batch = F.softmax(head(hu[st:ed], H[cands[st:ed]]), dim=-1)[:, 1]
            scores.append(s_batch)
        scores = torch.cat(scores, dim=0)
        s_true = scores[cands == v_true][0]
        rank = 1 + (scores > s_true).sum().item()
        if rank <= 10: hit10 += 1
    h10 = torch.tensor(hit10/float(P), device=device)
    return {"hits@10": h10}

@torch.no_grad()
def _false_neg_mask_by_adj(pos, neg, adj_sets, batch=65536):
    """
    (u, v_neg)가 실제 양성(=adj_sets[u]에 v_neg 존재)이면 True로 표시.
    성능/메모리 절충을 위해 배치로 membership 검사.
    """
    if adj_sets is None:  # 제공 안되면 필터 스킵
        return torch.zeros(neg.size(1), dtype=torch.bool, device=neg.device)
    M = neg.size(1)
    mask = torch.zeros(M, dtype=torch.bool, device=neg.device)
    for st in range(0, M, batch):
        ed = min(st+batch, M)
        u = neg[0, st:ed].tolist()
        v = neg[1, st:ed].tolist()
        for i, uu in enumerate(u):
            if v[i] in adj_sets[uu]:
                mask[st+i] = True
    return mask

@torch.no_grad()
def select_hard_negatives(pos, neg_pool, H, head, adj_sets=None,
                          strategy="topk", topk_per_pos=1,
                          semi_low=0.4, semi_high=0.7):
    """
    pos : [2, P]
    neg_pool : [2, P * k_eff]  (pos별로 k_eff개씩 이어붙은 형태)
    반환: [2, P * chosen_per_pos] 의 하드 음성만 (순서 유지 X)
    """
    device = H.device
    P = pos.size(1)
    if P == 0 or neg_pool is None or neg_pool.size(1) == 0:
        return neg_pool

    k_eff = max(1, neg_pool.size(1) // P)  # 각 pos당 후보 수
    # 점수 계산: p(y=1 | neg)
    s_neg = []
    # 큰 풀일 때 메모리 절약
    step = 131072
    for st in range(0, neg_pool.size(1), step):
        ed = min(st+step, neg_pool.size(1))
        batch_s = F.softmax(head(H[neg_pool[0, st:ed]], H[neg_pool[1, st:ed]]), dim=-1)[:, 1]
        s_neg.append(batch_s)
    s_neg = torch.cat(s_neg, dim=0)  # [M]

    # False negative 배제: 스코어 -inf 처리
    if adj_sets is not None:
        fn_mask = _false_neg_mask_by_adj(pos, neg_pool, adj_sets)
        s_neg = s_neg.masked_fill(fn_mask, float("-inf"))

    # pos별로 나눠서 상위 선택
    s_neg = s_neg.view(P, k_eff)
    neg_pool_u = neg_pool[0].view(P, k_eff)
    neg_pool_v = neg_pool[1].view(P, k_eff)

    if strategy == "topk":
        k = min(topk_per_pos, k_eff)
        vals, idx = torch.topk(s_neg, k=k, dim=1, largest=True, sorted=False)
        rows = torch.arange(P, device=device).unsqueeze(1).expand_as(idx)
        hard_u = neg_pool_u[rows, idx].reshape(-1)
        hard_v = neg_pool_v[rows, idx].reshape(-1)
        return torch.stack([hard_u, hard_v], dim=0)

    elif strategy == "semi":
        # 중간 난이도만 남기고, pos마다 개수 맞춰 샘플링
        keep = (s_neg >= semi_low) & (s_neg <= semi_high)
        hard_u_list, hard_v_list = []
        for i in range(P):
            cand_u = neg_pool_u[i][keep[i]]
            cand_v = neg_pool_v[i][keep[i]]
            if cand_u.numel() == 0:  # 없으면 상위로 fallback
                # 상위 1개라도 확보
                top_idx = torch.argmax(s_neg[i])
                cand_u = neg_pool_u[i][top_idx:top_idx+1]
                cand_v = neg_pool_v[i][top_idx:top_idx+1]
            # 원하는 개수만큼 샘플
            if cand_u.numel() > topk_per_pos:
                ridx = torch.randperm(cand_u.numel(), device=device)[:topk_per_pos]
                cand_u, cand_v = cand_u[ridx], cand_v[ridx]
            hard_u_list.append(cand_u)
            hard_v_list.append(cand_v)
        hard_u = torch.cat(hard_u_list, dim=0)
        hard_v = torch.cat(hard_v_list, dim=0)
        return torch.stack([hard_u, hard_v], dim=0)

    else:
        # 알 수 없는 전략이면 그대로 반환
        return neg_pool

