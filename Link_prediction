    ).to(device)
    opt = torch.optim.Adam(list(enc.parameters()) + list(ph.parameters()) + list(dh.parameters()), lr=args.lr)
    return enc, ph, gr, dh, opt

def train_one_trial(neg_ratio, grl_lambda_max, entropy_w, max_epochs,
                    keep_src_pairs_local, keep_tgt_pairs_local):
    """
    - 트라이얼 내부 스케줄: ep/max_epochs 기반
    - 평가: TGT/SRC 모두 AUC + ACC@best (임계값 탐색)
    - early stopping: TGT AUC 기준
    - CE 가중치 토글(args.balance_ce)
    """
    best_tgt_auc = 0.0; best_tgt_acc = 0.0
    best_src_auc = 0.0; best_src_acc = 0.0
    best_ep = 0
    patience_counter_local = 0

    encoder_l, pair_head_l, grl_l, domain_head_l, optim_l = init_models_for_trial()

    for ep in range(1, max_epochs+1):
        encoder_l.train(); pair_head_l.train(); domain_head_l.train()
        optim_l.zero_grad()

        # 🔸 스케줄: 트라이얼 길이 기준
        prog = ep / float(max_epochs)
        lambd = min(prog, grl_lambda_max)
        grl_l.set_lambda(lambd)
        entw_now = prog * entropy_w

        # 임베딩
        Hs = encoder_l(src.edge_index.to(device), src.edge_type.to(device))
        Ht = encoder_l(tgt.edge_index.to(device), tgt.edge_type.to(device))

        # 소스 CE
        pos_all, _ = sample_pos_neg_edges(src.edge_index.to(device), src.num_nodes, device=device)
        if pos_all is not None:
            mpos = filter_edges_by_domain_pairs(pos_all, src.node_domain, keep_src_pairs_local)
            pos = pos_all[:, mpos]
        else:
            pos = None

        if pos is None or pos.size(1) == 0:
            cls_loss = torch.tensor(0.0, device=device)
        else:
            hu_pos, hv_pos = Hs[pos[0]], Hs[pos[1]]
            log_pos = pair_head_l(hu_pos, hv_pos)
            y_pos = torch.ones(log_pos.size(0), dtype=torch.long, device=device)

            neg = sample_neg_domain_matched(pos, src.node_domain, src.nodes_by_domain,
                                            k=neg_ratio, max_negs=args.max_negs, device=device)
            hu_neg, hv_neg = Hs[neg[0]], Hs[neg[1]]
            log_neg = pair_head_l(hu_neg, hv_neg)
            y_neg = torch.zeros(log_neg.size(0), dtype=torch.long, device=device)

            logits = torch.cat([log_pos, log_neg], dim=0)
            y = torch.cat([y_pos, y_neg], dim=0)

            if getattr(args, "balance_ce", True):
                P, N = y_pos.numel(), y_neg.numel()
                total = float(P + N) + 1e-12
                w_neg = total / (2.0 * float(N) + 1e-12)
                w_pos = total / (2.0 * float(P) + 1e-12)
                weights = torch.tensor([w_neg, w_pos], device=device, dtype=torch.float)
                cls_loss = F.cross_entropy(logits, y, weight=weights)
            else:
                cls_loss = F.cross_entropy(logits, y)

        # GRL
        ds = domain_head_l(Hs); dt = domain_head_l(Ht)
        y_ds = torch.zeros(ds.size(0), dtype=torch.long, device=device)
        y_dt = torch.ones(dt.size(0),  dtype=torch.long, device=device)
        grl_loss = F.cross_entropy(torch.cat([ds, dt], dim=0), torch.cat([y_ds, y_dt], dim=0))

        # 타깃 엔트로피
        Eh_t = tgt.edge_index.size(1)//2
        if Eh_t > 0:
            pos_t = tgt.edge_index[:, :Eh_t].to(device)
            mask_inter = filter_edges_by_domain_pairs(pos_t, tgt.node_domain, keep_tgt_pairs_local)
            if mask_inter.any():
                idx = torch.nonzero(mask_inter, as_tuple=False).view(-1)
                if idx.numel() > 2048:
                    idx = idx[torch.randperm(idx.numel(), device=device)[:2048]]
            else:
                idx = torch.randint(0, Eh_t, (min(2048, Eh_t),), device=device)
            u_t = pos_t[0, idx]; v_t = pos_t[1, idx]
            pt = F.softmax(pair_head_l(Ht[u_t], Ht[v_t]), dim=-1).clamp_min(1e-9)
            ent_loss = -(pt * pt.log()).sum(dim=-1).mean()
        else:
            ent_loss = torch.tensor(0.0, device=device)

        # L2
        reg = torch.tensor(0.0, device=device)
        for m in [encoder_l, pair_head_l]:
            for p in m.parameters():
                if p.requires_grad and p.dim() > 1:
                    reg = reg + 1e-4 * (p**2).mean()

        loss = cls_loss + grl_loss + entw_now * ent_loss + reg
        loss.backward()
        torch.nn.utils.clip_grad_norm_(list(encoder_l.parameters()) + list(pair_head_l.parameters()), 5.0)
        optim_l.step()

# 평가: TGT + SRC (AUC, ACC@best)
        encoder_l.eval(); pair_head_l.eval()
        with torch.no_grad():
            Hs_eval = encoder_l(src.edge_index.to(device), src.edge_type.to(device))
            Ht_eval = encoder_l(tgt.edge_index.to(device), tgt.edge_type.to(device))

            src_metrics = eval_link_metrics(
                Hs_eval, src.edge_index.to(device), pair_head_l,
                restrict_pairs=keep_src_pairs_local, node_domain=src.node_domain.to(device),
                sample_limit=args.eval_sample_limit,
                nodes_by_domain=src.nodes_by_domain,
                domain_matched_neg=True, return_best=True
            )
            tgt_metrics = eval_link_metrics(
                Ht_eval, tgt.edge_index.to(device), pair_head_l,
                restrict_pairs=keep_tgt_pairs_local, node_domain=tgt.node_domain.to(device),
                sample_limit=args.eval_sample_limit,
                nodes_by_domain=tgt.nodes_by_domain,
                domain_matched_neg=True, return_best=True
            )

        # early stopping: TGT AUC
        score_auc_t = tgt_metrics['auc'].item()
        if score_auc_t > best_tgt_auc:
            best_tgt_auc = score_auc_t
            best_tgt_acc = tgt_metrics['acc_best'].item()
            best_src_auc = src_metrics['auc'].item()
            best_src_acc = src_metrics['acc_best'].item()
            best_ep = ep
            patience_counter_local = 0
        else:
            patience_counter_local += 1
            if patience_counter_local >= args.patience:
                break

    return {
        "best_ep": best_ep,
        "tgt_auc": best_tgt_auc,
        "tgt_acc": best_tgt_acc,  # ACC@best
        "src_auc": best_src_auc,
        "src_acc": best_src_acc,  # ACC@best
        "neg_ratio": neg_ratio,
        "grl_lambda_max": grl_lambda_max,
        "entropy_w": entropy_w,
    }

def run_grid_search():
    combos = list(itertools.product(args.search_neg_ratio,
                                    args.search_grl_lambda,
