def _score_pack(logits, *, score_mode="link", temperature=1.0, alpha_no_link_bias=0.0):
    """
    logits: [B, 1+R] (0: No_Link, 1..R: relations)
    반환값:
      p_link: 1 - p(No_Link)
      p_best: max_rel_prob
      winner_rel: argmax over 1..R  (No_Link는 제외)
      score: 선택한 score_mode에 따른 최종 점수
    """
    # 온도/바이어스 보정
    if alpha_no_link_bias != 0.0:
        logits = logits.clone()
        logits[:, 0] = logits[:, 0] - float(alpha_no_link_bias)
    if temperature and temperature != 1.0:
        logits = logits / float(temperature)

    prob = F.softmax(logits, dim=-1)                  # [B, 1+R]
    p_no  = prob[:, 0]
    p_rel = prob[:, 1:]
    p_best, winner_rel = torch.max(p_rel, dim=1)      # [B], [B] (0..R-1)

    if score_mode == "link":
        score = 1.0 - p_no
    elif score_mode == "rel":
        score = p_best
    elif score_mode == "margin":
        # 로짓 margin: max_rel_logit - no_link_logit
        # (확률보다 덜 포화되고 랭킹 친화적)
        max_rel_logit, _ = torch.max(logits[:, 1:], dim=1)
        score = max_rel_logit - logits[:, 0]
    else:
        raise ValueError(f"Unknown score_mode: {score_mode}")

    p_link = 1.0 - p_no
    return p_link, p_best, winner_rel, score

def predict_joint_flexible(
    H, data, head,
    directions=("AI->AE","AE->AI"),      # 기본: AI->MB만
    thr=0.25,                    # 내가 직접 조절
    score_mode="link",           # "link" | "rel" | "margin"
    min_prob_rel=None,           # 관계타입 최소 확률 (예: 0.1~0.2)
    temperature=1.0,
    alpha_no_link_bias=0.0,      # No_Link 로짓 깎기 (예: 0.3~1.0)
    top_k_per_src=None,          # 각 소스 노드별 상위 K 보정 포함 (예: 50)
    batch=4096,
    exclude_existing=True,
    csv_path="scopus_pred_edges_AE.csv"
):
    device = H.device
    R = int(data.num_rel)

    # 안전 가드
    N = int(getattr(data, "num_nodes"))
    if H.size(0) < N:
        raise RuntimeError(f"[FATAL] H.size(0)={H.size(0)} < data.num_nodes={N}")
    if H.size(0) != N:
        H = H.narrow(0, 0, N)

    Eh = int(data.edge_index.size(1) // 2)
    existing = set()
    if exclude_existing and Eh > 0:
        pos = data.edge_index[:, :Eh].detach().cpu().numpy().T.tolist()
        existing.update((u, v) for u, v in pos)

    dom_name = {0: "AI", 1: "MB", 2: "AE"}
    dom_id   = {"AI": 0, "MB": 1, "AE": 2}

    # rel id → 이름
    id2rel = [None] * R
    for name, rid in meta.rel2id.items():
        if isinstance(rid, int) and 0 <= rid < R:
            id2rel[rid] = str(name)
    for i in range(R):
        if id2rel[i] is None:
            id2rel[i] = f"REL_{i}"

    # idx→identity / identity→name
    idx2identity = _build_idx2identity_from_subgraph(data)
    id2name_nodes = _build_identity2name_from_nodes(data)

    rows = []

    for direc in directions:
        if "->" not in direc:
            raise ValueError(f"direction '{direc}' is invalid. ex) 'AI->MB")
        s_dom_req, t_dom_req = direc.split("->")
        s_id_req, t_id_req = dom_id[s_dom_req], dom_id[t_dom_req]

        src_nodes = torch.nonzero(data.node_domain == s_id_req, as_tuple=False).view(-1).tolist()
        dst_nodes = torch.nonzero(data.node_domain == t_id_req, as_tuple=False).view(-1).tolist()
        if len(src_nodes) == 0 or len(dst_nodes) == 0:
            print(f"[WARN] No nodes for direction {direc}. src={len(src_nodes)}, dst={len(dst_nodes)}")
            continue

        vs_all = torch.tensor(dst_nodes, device=device, dtype=torch.long)

        for u in src_nodes:
            scores_u = []
            keep_idxs_u = []  # (local idx in vs_all, score, p_link, p_best, winner_rel)

            for st in range(0, vs_all.numel(), batch):
                ve = min(st + batch, vs_all.numel())
                vs = vs_all[st:ve]
                if vs.numel() == 0:
                    continue

                hu = H[u].unsqueeze(0).expand(vs.size(0), -1)
                hv = H[vs]
                logits = head(hu, hv)  # (B, 1+R)

                p_link, p_best, winner_rel, score = _score_pack(
                    logits,
                    score_mode=score_mode,
                    temperature=temperature,
                    alpha_no_link_bias=alpha_no_link_bias
                )

                # 임계값 기반 1차 필터
                mask_thr = (score >= float(thr))
                if min_prob_rel is not None:
                    mask_thr = mask_thr & (p_best >= float(min_prob_rel))

                # 후보 기록 (threshold 통과분)
                if mask_thr.any():
                    kept = torch.nonzero(mask_thr, as_tuple=False).view(-1)
                    for j in kept.tolist():
                        keep_idxs_u.append((
                            int(st + j),
                            float(score[j].item()),
                            float(p_link[j].item()),
                            float(p_best[j].item()),
                            int(winner_rel[j].item())
                        ))

                # Top-K 보정용으로 전체 점수(현재 배치)도 저장
                scores_u.append((
                    st,
                    score.detach().to('cpu'),
                    p_link.detach().to('cpu'),
                    p_best.detach().to('cpu'),
                    winner_rel.detach().to('cpu')
                ))

            # ─ Top-K per source 보정 ─
            if top_k_per_src is not None and top_k_per_src > 0:
                # 모든 배치를 이어붙여 상위 K 추출
                score_cat = torch.cat([x[1] for x in scores_u], dim=0)  # CPU
                plink_cat = torch.cat([x[2] for x in scores_u], dim=0)
                pbest_cat = torch.cat([x[3] for x in scores_u], dim=0)
                wrel_cat  = torch.cat([x[4] for x in scores_u], dim=0)
                k = min(int(top_k_per_src), score_cat.numel())
                if k > 0:
                    topk_val, topk_idx = torch.topk(score_cat, k=k, largest=True, sorted=False)
                    for idx_local in topk_idx.tolist():
                        keep_idxs_u.append((
                            int(idx_local),
                            float(score_cat[idx_local].item()),
                            float(plink_cat[idx_local].item()),
                            float(pbest_cat[idx_local].item()),
                            int(wrel_cat[idx_local].item())
                        ))

            # 중복 제거 (threshold 통과 + top-k)
            if keep_idxs_u:
                # 같은 v가 여러 경로로 들어오면 score 최대값만 남김
                best_by_v = {}
                for local_idx, sc, pl, pb, wr in keep_idxs_u:
                    v = int(vs_all[local_idx].item())
                    if exclude_existing and (u, v) in existing:
                        continue
                    key = (u, v)
                    cur = best_by_v.get(key)
                    if (cur is None) or (sc > cur[0]):
                        best_by_v[key] = (sc, pl, pb, wr)

                # 행으로 저장
                for (uu, vv), (sc, pl, pb, wr) in best_by_v.items():
                    # 도메인 가드 (AI→MB)
                    src_dom_true = int(data.node_domain[int(uu)].item())
                    dst_dom_true = int(data.node_domain[int(vv)].item())
                    if src_dom_true != s_id_req or dst_dom_true != t_id_req:
                        continue

                    rid = int(wr)
                    src_ident = idx2identity.get(int(uu))
                    dst_ident = idx2identity.get(int(vv))
                    src_name = id2name_nodes.get(src_ident, str(int(uu)))
                    dst_name = id2name_nodes.get(dst_ident, str(int(vv)))
                    rows.append((
                        int(uu), int(vv),
                        src_ident, dst_ident,
                        float(pl), rid, id2rel[rid],
                        src_name, dst_name,
                        src_dom_true, dst_dom_true,
                        float(sc), float(pb)  # score, p_best 추가
                    ))

    df = pd.DataFrame(
        rows,
        columns=[
            "src_id", "dst_id",
            "src_identity", "dst_identity",
            "link_prob", "rel_id", "rel_type",
            "src_name", "dst_name",
