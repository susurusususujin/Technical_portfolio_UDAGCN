def _coerce_int(x):
    try: return int(x)
    except Exception: return None

def build_and_attach_idx_name_map_from_triplets(data, triples,
                                                idx2id_attr_candidates=("idx2id","id_of_idx","orig_id","orig_ids")):
    dbid2name = {}
    for rec in triples:
        for k in ("n","m"):
            node = rec.get(k, {})
            if not isinstance(node, dict): continue
            dbid = node.get("identity", None)
            name = _extract_name(node.get("properties", {}))
            if dbid is not None and name:
                dbid_i = _coerce_int(dbid)
                if dbid_i is not None:
                    dbid2name[dbid_i] = name
    idx2dbid = None
    for attr in idx2id_attr_candidates:
        if hasattr(data, attr):
            m = getattr(data, attr)
            if torch.is_tensor(m): m = m.detach().cpu().tolist()
            if isinstance(m, dict):
                idx2dbid = { _coerce_int(i): _coerce_int(v) for i, v in m.items() }
            elif isinstance(m, (list, tuple)):
                idx2dbid = { int(i): _coerce_int(v) for i, v in enumerate(m) }
            break
    if idx2dbid is not None:
        id2name = { int(idx): dbid2name.get(int(db), str(idx))
                    for idx, db in idx2dbid.items() if idx is not None and db is not None }
    else:
        id2name = { int(db): nm for db, nm in dbid2name.items() }
    data.id2name = id2name
    data._id2name_cache = id2name
    print(f"✅ Attached {len(id2name)} idx→name mappings from NM-triplets.")
