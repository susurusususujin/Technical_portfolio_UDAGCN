def _map_name(identity):
    if identity is None or (isinstance(identity, float) and math.isnan(identity)):
        return None
    return id2name.get(int(identity))

def _map_props(identity):
    if identity is None or (isinstance(identity, float) and math.isnan(identity)):
        return {}
    return id2props.get(int(identity), {})

