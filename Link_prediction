def joint_batch_loss(H, edge_index, edge_type, head,
                     node_domain, nodes_by_domain,
                     restrict_pairs, neg_ratio, device):
    edge_index = edge_index.to(device=device, dtype=torch.long).contiguous()
    edge_type  = edge_type.to(device=device, dtype=torch.long).contiguous()
    nd = node_domain.to(device=device, dtype=torch.long)

    Eh = edge_index.size(1)//2
    pos_uv = edge_index[:, :Eh]
    pos_r  = edge_type[:Eh]

    s, t = pos_uv[0], pos_uv[1]
    ds, dt = nd[s], nd[t]
    mask = torch.zeros(Eh, dtype=torch.bool, device=device)
    for (a,b) in restrict_pairs:
        mask |= ((ds == a) & (dt == b))
    pos_uv, pos_r = pos_uv[:, mask], pos_r[mask]
    P = pos_uv.size(1)
    if P == 0:
        return torch.tensor(0.0, device=device, requires_grad=True)

    # positive: 라벨 1..R
    hu_pos, hv_pos = H[pos_uv[0]], H[pos_uv[1]]
    logits_pos = head(hu_pos, hv_pos)
    y_pos = pos_r + 1

    # negative: 라벨 0
    neg_uv = sample_neg_pairs(pos_uv, node_domain, nodes_by_domain, k=int(neg_ratio), device=device)
    hu_neg, hv_neg = H[neg_uv[0]], H[neg_uv[1]]
    logits_neg = head(hu_neg, hv_neg)
    y_neg = torch.zeros(logits_neg.size(0), dtype=torch.long, device=device)

    logits = torch.cat([logits_pos, logits_neg], dim=0)
    labels = torch.cat([y_pos, y_neg], dim=0)
    return F.cross_entropy(logits, labels)

