def load_json_bomsafe(path: str):
    p = Path(path)
    if not p.exists():
        raise FileNotFoundError(f"JSON not found: {path}")
    with open(p, "r", encoding="utf-8-sig") as f:
        txt = f.read()
    try:
        return json.loads(txt)
    except json.JSONDecodeError as e:
        items = []
        for line in txt.splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
                items.append(obj)
            except Exception:
                pass
        if items:
            return items
        raise e

def _extract_name_from_any(d: dict):
    if not isinstance(d, dict):
        return None
    props = d.get("properties", d) or {}
    for k in ("name", "Name", "label", "title"):
        v = props.get(k)
        if isinstance(v, str) and v.strip():
            return v.strip()
    return None

def build_identity_maps(json_path: str):
    data = load_json_bomsafe(json_path)

    records = []
    if isinstance(data, list):
        records = data
    elif isinstance(data, dict):
        def walk(x):
            if isinstance(x, dict):
                if ("n" in x and "m" in x) or ("n" in x and "r" in x):
                    records.append(x)
                for v in x.values():
                    walk(v)
            elif isinstance(x, list):
                for v in x:
                    walk(v)
        walk(data)
    else:
        records = []

    id2name, id2props = {}, {}

    def visit_node(node_like):
        if not isinstance(node_like, dict):
            return
        ident = node_like.get("identity", None)
        if ident is None:
            return
        try:
            ident = int(ident)
        except Exception:
            return
        props = node_like.get("properties", {}) or {}
        if ident not in id2props:
            id2props[ident] = props
        nm = _extract_name_from_any(node_like)
        if nm:
            id2name[ident] = nm

    for rec in records:
        visit_node(rec.get("n"))
        visit_node(rec.get("m"))

    print(f"• identity→name loaded: {len(id2name)} | identity→properties: {len(id2props)}")
    return id2name, id2props

def _to_int_series(s):
    def _coerce(x):
        try:
            if pd.isna(x): return None
            return int(float(x))
        except Exception:
            return None
    return s.apply(_coerce)

