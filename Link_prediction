@torch.no_grad()
def eval_joint_reltype_with_nolink(
    encoder, joint_head, graph, num_rel, restrict_pairs,
    neg_ratio_eval=10, sample_limit_pos=4096, sample_limit_neg=None, batch=2048, device=None
):
    if device is None: device = next(encoder.parameters()).device
    encoder.eval(); joint_head.eval()

    edge_index = graph.edge_index.to(device=device, dtype=torch.long).contiguous()
    edge_type  = graph.edge_type.to(device=device, dtype=torch.long).contiguous()
    nd         = graph.node_domain.to(device=device, dtype=torch.long)

    Eh = edge_index.size(1)//2
    if Eh == 0:
        z = torch.tensor(0.0, device=device); C = num_rel+1
        return {"acc": z, "auc_macro": z, "mrr": z, "hits10": z,
                "micro_f1": z, "macro_f1": z, "weighted_f1": z,
                "per_class_f1": torch.zeros(C, device=device), "n_pos": 0, "n_neg": 0}

    uv_pos = edge_index[:, :Eh]; r_pos = edge_type[:Eh]
    ds, dt = nd[uv_pos[0]], nd[uv_pos[1]]
    mask = torch.zeros(Eh, dtype=torch.bool, device=device)
    for (a,b) in restrict_pairs: mask |= ((ds==a) & (dt==b))
    uv_pos, r_pos = uv_pos[:, mask], r_pos[mask]
    P = int(uv_pos.size(1))
    if P == 0:
        z = torch.tensor(0.0, device=device); C = num_rel+1
        return {"acc": z, "auc_macro": z, "mrr": z, "hits10": z,
                "micro_f1": z, "macro_f1": z, "weighted_f1": z,
                "per_class_f1": torch.zeros(C, device=device), "n_pos": 0, "n_neg": 0}

    if P > sample_limit_pos:
        idx = torch.randperm(P, device=device)[:sample_limit_pos]
        uv_pos, r_pos = uv_pos[:, idx], r_pos[idx]; P = int(uv_pos.size(1))

    if sample_limit_neg is None: sample_limit_neg = P * neg_ratio_eval
    neg_uv = sample_neg_pairs(uv_pos, graph.node_domain, graph.nodes_by_domain,
                              k=int(neg_ratio_eval), device=device)
    N = int(neg_uv.size(1)) if neg_uv is not None else 0
    if N > sample_limit_neg:
        idxn = torch.randperm(N, device=device)[:sample_limit_neg]
        neg_uv = neg_uv[:, idxn]; N = int(neg_uv.size(1))

    H = encoder(edge_index, graph.edge_type.to(device))

    logits_pos=[]; 
    for st in range(0, P, batch):
        ed = min(st+batch, P)
        logits_pos.append(joint_head(H[uv_pos[0,st:ed]], H[uv_pos[1,st:ed]]))
    logits_pos = torch.cat(logits_pos, dim=0) if len(logits_pos)>0 else torch.empty((0, num_rel+1), device=device)
    y_pos = r_pos + 1

    logits_neg=[]
    if N>0:
        for st in range(0, N, batch):
            ed = min(st+batch, N)
            logits_neg.append(joint_head(H[neg_uv[0,st:ed]], H[neg_uv[1,st:ed]]))
    logits_neg = torch.cat(logits_neg, dim=0) if len(logits_neg)>0 else torch.empty((0, num_rel+1), device=device)
    y_neg = torch.zeros((N,), dtype=torch.long, device=device)

    logits = torch.cat([logits_pos, logits_neg], dim=0)
    labels = torch.cat([y_pos, y_neg], dim=0)
    T = int(labels.numel())
    if T == 0:
        z = torch.tensor(0.0, device=device); C = num_rel+1
        return {"acc": z, "auc_macro": z, "mrr": z, "hits10": z,
                "micro_f1": z, "macro_f1": z, "weighted_f1": z,
                "per_class_f1": torch.zeros(C, device=device), "n_pos": 0, "n_neg": 0}

    probs = F.softmax(logits, dim=-1)
    pred  = probs.argmax(dim=1)
    acc = (pred == labels).float().mean()

    C = num_rel + 1
    f1s = torch.zeros(C, device=device); supports = torch.zeros(C, device=device)
    for c in range(C):
        tp = ((pred == c) & (labels == c)).sum().item()
        fp = ((pred == c) & (labels != c)).sum().item()
        fn = ((pred != c) & (labels == c)).sum().item()
        supp = (labels == c).sum().item()
        supports[c] = float(supp)
        prec = tp / max(1, tp+fp); rec = tp / max(1, tp+fn)
        f1s[c] = 2*prec*rec / max(1e-12, (prec+rec)) if (prec+rec) > 0 else 0.0
    macro_f1 = f1s.mean()
    weighted_f1 = ((supports/float(T))*f1s).sum()

    # 멀티클래스 MRR/H@10 (클래스 확률 랭크)
    s_true = probs.gather(1, labels.view(-1,1)).squeeze(1)
    ranks = 1 + (probs > s_true.unsqueeze(1)).sum(dim=1)
    hits10 = (ranks <= min(C,10)).float().mean()
    mrr = (1.0/ranks.float()).mean()

    # OVR AUC macro
    auc_sum=0.0; auc_cnt=0
    for c in range(C):
        y_bin = (labels==c); n_pos = int(y_bin.sum().item()); n_neg = T - n_pos
        if n_pos==0 or n_neg==0: continue
        s = probs[:, c]
        sorted_s, order = torch.sort(s)
        rks = torch.empty_like(order, dtype=torch.float); rks[order]=torch.arange(1,T+1, device=device, dtype=torch.float)
        pos_rks = rks[y_bin]
        auc_c = (pos_rks.sum() - (n_pos*(n_pos+1)/2.0)) / (n_pos*n_neg + 1e-12)
        auc_sum += float(auc_c.item()); auc_cnt += 1
    auc_macro = torch.tensor(auc_sum/max(1,auc_cnt), device=device)

    return {
        "acc": acc, "auc_macro": auc_macro, "mrr": mrr, "hits10": hits10,
        "micro_f1": acc.clone(), "macro_f1": macro_f1, "weighted_f1": weighted_f1,
        "per_class_f1": f1s, "n_pos": P, "n_neg": N
    }

