# 메모리 최적화: 스트리밍 랭킹 (거대한 s_all 생성 안 함)
# ───────────────────────────────────────────────────────────────────────────────
@torch.inference_mode()
def eval_ranking_metrics_mrr(
    H, edge_index, head, node_domain, restrict_pairs, nodes_by_domain,
    adj=None, sample_queries=300, filtered=True, batch_size=512, device=None
):
    # 링크존재 랭킹 지표 (참고용). 점수 = 1 - p(No_Link)
    device = device or H.device
    edge_index = edge_index.to(device=device, dtype=torch.long).contiguous()
    nd = node_domain.to(device=device, dtype=torch.long)
    Eh = edge_index.size(1) // 2
    if Eh == 0:
        z = torch.tensor(0.0, device=device)
        return {'hits@10': z, 'mrr': z, 'queries': 0}

    uv = edge_index[:, :Eh]
    ds, dt = nd[uv[0]], nd[uv[1]]
    mask = torch.zeros(Eh, dtype=torch.bool, device=device)
    for (a, b) in restrict_pairs:
        mask |= ((ds == a) & (dt == b))
    uv = uv[:, mask]
    P = uv.size(1)
    if P == 0:
        z = torch.tensor(0.0, device=device)
        return {'hits@10': z, 'mrr': z, 'queries': 0}

    if sample_queries and P > sample_queries:
        idx = torch.randperm(P, device=device)[:sample_queries]
        uv = uv[:, idx]
    Q = int(uv.size(1))

    # 필터링용 인접 사전 (CPU set)
    py_adj = None
    if filtered:
        if isinstance(adj, dict):
            py_adj = adj
        else:
            uv_cpu = uv.detach().cpu().numpy().T
            py_adj = {}
            for u_i, v_i in uv_cpu:
                py_adj.setdefault(int(u_i), set()).add(int(v_i))

    head.eval()
    tot_rr = 0.0
    tot_hits10 = 0.0

    for i in range(Q):
        u = int(uv[0, i].item())
        v_true = int(uv[1, i].item())
        t_dom = int(nd[v_true].item())

        # 도메인 후보 풀 (CPU에서 필터링 후 GPU로 올리기)
        pool_tensor = nodes_by_domain.get(t_dom, torch.nonzero(nd == t_dom, as_tuple=False).view(-1))
        pool_list = pool_tensor.detach().cpu().tolist()

        if filtered and py_adj is not None:
            forbid = py_adj.get(u, set())
            if v_true in forbid:
                # true는 허용
                forbid = set(forbid) - {v_true}
            if forbid:
                forbid = set(int(x) for x in forbid)
                pool_list = [x for x in pool_list if x not in forbid]

        if v_true not in pool_list:
            pool_list.append(v_true)

        pool = torch.tensor(pool_list, dtype=torch.long, device=device)

        # s_true 한 번만 계산
        hu = H[u].unsqueeze(0)
        hv_true = H[v_true].unsqueeze(0)
        logits_true = head(hu, hv_true)               # [1, C]
        # log_softmax 사용: 수치안정 + 메모리 적음
        logp_true = F.log_softmax(logits_true, dim=-1)
        s_true = (1.0 - torch.exp(logp_true[:, 0]))   # 1 - p(No_Link), shape [1]
        s_true_val = float(s_true.item())

        num_greater = 0
        # 스트리밍 비교: s_batch > s_true 만 세서 rank 계산
        for st in range(0, pool.numel(), batch_size):
            vs = pool[st: st + batch_size]
            hv = H[vs]  # [B, d]
            logits = head(hu.expand(vs.size(0), -1), hv)  # [B, C]
            logp = F.log_softmax(logits, dim=-1)
            s_batch = 1.0 - torch.exp(logp[:, 0])  # [B]
            # v_true가 포함되어 있어도 > 비교이므로 자신은 카운트 안 됨
            num_greater += int((s_batch > s_true_val).sum().item())

        rank = 1 + num_greater
        tot_rr += 1.0 / float(rank)
        if rank <= 10:
            tot_hits10 += 1.0

    mrr = torch.tensor(tot_rr / float(Q), device=device)
    hits10 = torch.tensor(tot_hits10 / float(Q), device=device)
    return {'hits@10': hits10, 'mrr': mrr, 'queries': Q}

# ───────────────────────────────────────────────────────────────────────────────
# 타입 랭킹 평가: 점수 행렬 CPU에 적재(큰 텐서가 GPU 상주하지 않도록)
# ───────────────────────────────────────────────────────────────────────────────
@torch.inference_mode()
def eval_reltype_metrics_udagcn(encoder, joint_head, graph, num_rel, restrict_pairs,
                                sample_limit=2048, batch=256, device=None):
    device = device or next(encoder.parameters()).device
    encoder.eval(); joint_head.eval()
    edge_index = graph.edge_index.to(device=device, dtype=torch.long).contiguous()
    edge_type  = graph.edge_type.to(device=device, dtype=torch.long).contiguous()
    nd         = graph.node_domain.to(device=device, dtype=torch.long)
    Eh = edge_index.size(1)//2
    if Eh == 0:
        z = torch.tensor(0.0, device=device)
        return {"acc": z, "hits3": z, "hits10": z, "mrr": z, "macro_f1": z, "auc_macro": z, "n": 0}

    uv = edge_index[:, :Eh]; r  = edge_type[:Eh]
    ds, dt = nd[uv[0]], nd[uv[1]]
    mask = torch.zeros(Eh, dtype=torch.bool, device=device)
    for (a, b) in restrict_pairs:
        mask |= ((ds == a) & (dt == b))
    uv, r = uv[:, mask], r[mask]; P = uv.size(1)
    if P == 0:
        z = torch.tensor(0.0, device=device)
        return {"acc": z, "hits3": z, "hits10": z, "mrr": z, "macro_f1": z, "auc_macro": z, "n": 0}

    if P > sample_limit:
        idx = torch.randperm(P, device=device)[:sample_limit]
        uv = uv[:, idx]; r = r[idx]; P = int(uv.size(1))

    # 임베딩 1회 계산 (AMP로 메모리/연산 절감)
    with torch.cuda.amp.autocast():
        H = encoder(edge_index, edge_type)

    top1 = hit3 = hit10 = 0
    rr_sum = 0.0

    # 큰 행렬은 CPU에 저장
    import math
    scores_all_cpu = torch.empty((P, num_rel), dtype=torch.float32, device='cpu')
    labels_all_cpu = r.detach().to('cpu')
    out_row = 0

    for st in range(0, P, batch):
        ed = min(st + batch, P)
        u = uv[0, st:ed]; v = uv[1, st:ed]; r_true = r[st:ed]; B = u.size(0)

        with torch.cuda.amp.autocast():
            logits_full = joint_head(H[u], H[v])              # [B, 1 + num_rel + (maybe others?)]
            logits_rel = logits_full[:, 1:1+num_rel]          # No_Link 제외

        # 순위 통계(메모리 적게): 배치 내부에서만 사용 후 버림
        s_true = logits_rel.gather(1, r_true.view(-1, 1)).squeeze(1)  # [B]
        ranks = 1 + (logits_rel > s_true.unsqueeze(1)).sum(dim=1)
        top1  += int((ranks == 1).sum().item())
        hit3  += int((ranks <= 3).sum().item())
        hit10 += int((ranks <= 10).sum().item())
        rr_sum += float((1.0 / ranks.float()).sum().item())

        # CPU로 즉시 옮겨 저장
        scores_all_cpu[out_row:out_row+B] = logits_rel.detach().to('cpu')
        out_row += B

        # GPU 메모리 정리
        del logits_full, logits_rel, s_true, ranks
        if (st // batch) % 8 == 0:
            torch.cuda.empty_cache()

    acc = torch.tensor(top1/float(P), device=device)
    h3  = torch.tensor(hit3/float(P), device=device)
    h10 = torch.tensor(hit10/float(P), device=device)
    mrr = torch.tensor(rr_sum/float(P), device=device)

    # 간단 AUC(랭크 근사) — CPU에서 계산
    auc_sum = 0.0; auc_cnt = 0
    preds = scores_all_cpu.argmax(dim=1)
    uniq = labels_all_cpu.unique().tolist()
    for c in uniq:
        mask_pos = (labels_all_cpu == int(c))
        n_pos = int(mask_pos.sum().item()); n_neg = P - n_pos
        if n_pos == 0 or n_neg == 0:
            continue
        s = scores_all_cpu[:, int(c)]
        sorted_s, order = torch.sort(s)
        ranks = torch.empty_like(order, dtype=torch.float32)
        ranks[order] = torch.arange(1, P+1, dtype=torch.float32)
        pos_ranks = ranks[mask_pos]
        auc_c = (pos_ranks.sum() - (n_pos*(n_pos+1)/2.0)) / max(1.0, (n_pos*n_neg))
        auc_sum += float(auc_c.item()); auc_cnt += 1
    auc_macro = torch.tensor(auc_sum / max(1, auc_cnt), device=device)

    return {
        "acc": acc, "hits3": h3, "hits10": h10, "mrr": mrr,
        "macro_f1": torch.tensor(0.0, device=device),  # 필요시 F1 계산 루틴 추가
        "auc_macro": auc_macro, "n": int(P)
    }

# ───────────────────────────────────────────────────────────────────────────────
# Stage2 joint 훈련 (AMP + 빈번한 캐시 정리 + 중간평가 축소)
# ───────────────────────────────────────────────────────────────────────────────
def train_stage2_joint(epochs=STAGE2_EPOCHS, patience=STAGE2_PATIENCE,
                       eval_every=5, eval_sample_queries=300, eval_batch_size=512,
                       accum_steps=1):
    global src, tgt, encoder, joint_head, optim, grl, device, keep_src_pairs, adj_tgt

    # 그래프를 device로 올려놓고 재사용
    _to_device_graph(src, device)
    _to_device_graph(tgt, device)

    scaler = torch.cuda.amp.GradScaler(enabled=True)
    best_auc, best_ep, no_improve = 0.0, 0, 0

    encoder.train(); joint_head.train()
    optim.zero_grad(set_to_none=True)

    for ep in range(1, epochs + 1):
        prog = ep / epochs
        grl.set_lambda(min(GRL_MAX_STAGE2, GRL_MAX_STAGE2 * prog))

        # ─ Training step (AMP + optional gradient accumulation) ─
        with torch.cuda.amp.autocast():
            # src 그래프 임베딩
            Hs = encoder(src.edge_index, src.edge_type)

            # tgt forward for GRL: 내부에 도메인 분류기가 붙어있다면 필요
            # (메모리 압박 시 encoder 내부에서 노드/에지 샘플링을 지원한다면 mfg/cluster 등으로 소량만 통과 추천)
            _ = encoder(tgt.edge_index, tgt.edge_type)

            loss = joint_batch_loss(
                Hs,
                src.edge_index, src.edge_type,
                joint_head,
                src.node_domain, src.nodes_by_domain,
                restrict_pairs=keep_src_pairs,
                neg_ratio=JOINT_NEG_RATIO_STAGE2,
                device=device
            ) / accum_steps

        scaler.scale(loss).backward()

        if ep % accum_steps == 0:
            # unscale + clip + step
            scaler.unscale_(optim)
            torch.nn.utils.clip_grad_norm_(list(encoder.parameters()) + list(joint_head.parameters()), 5.0)
            scaler.step(optim)
            scaler.update()
            optim.zero_grad(set_to_none=True)

        # 불필요 텐서 제거
        del Hs, loss
        if ep % 2 == 0:
            torch.cuda.empty_cache()

        # ─ 중간 평가 (메모리 친화 파라미터로) ─
        if eval_every and (ep % eval_every == 0):
            encoder.eval(); joint_head.eval()
            with torch.no_grad(), torch.cuda.amp.autocast():
                Ht_eval = encoder(tgt.edge_index, tgt.edge_type)
            rank_tgt = eval_ranking_metrics_mrr(
                Ht_eval, tgt.edge_index, joint_head,
                tgt.node_domain, {(AI, AE), (AE, AI)}, tgt.nodes_by_domain, adj_tgt,
                sample_queries=eval_sample_queries, filtered=True, batch_size=eval_batch_size, device=device
            )
            print(f"[S2:{ep:03d}] Link MRR={rank_tgt['mrr']:.4f} H@10={rank_tgt['hits@10']:.4f}")
            del Ht_eval
            encoder.train(); joint_head.train()
            torch.cuda.empty_cache()

    print("✅ Stage2 done.")

