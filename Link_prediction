def train_for_epochs(num_epochs: int = 5):
    """
    - GRL/엔트로피 스케줄: 이번 조각 길이(num_epochs) 기준
    - CE 가중치 토글(args.balance_ce, 기본 True)
    - 로그: AUC/ACC/ACC@best/H@10 + P/N/neg_ratio
    - early stopping 기준: 타깃 AUC
    """
    global current_epoch, best_tgt, best_src, best_ep, patience_counter, stopped_early
    if stopped_early:
        print("⏹ Already early-stopped. Reset counters to continue.")
        return current_epoch, best_ep, best_src, best_tgt, True

    for it in range(1, num_epochs + 1):
        if current_epoch >= args.epochs:
            print(f"⏹ Reached max epochs ({args.epochs}).")
            stopped_early = True
            break

        current_epoch += 1               # 전역 에폭(누적)
        ep_global = current_epoch
        ep_local  = it                   # 이번 조각 내 에폭(1..num_epochs)

        encoder.train(); pair_head.train(); domain_head.train()
        optim.zero_grad()

        # 🔸 스케줄: 이번 조각 내 진행률 기준
        prog = ep_local / float(max(1, num_epochs))
        lambd = min(prog, args.grl_lambda_max)
        grl.set_lambda(lambd)
        entw_now = prog * args.entropy_w

        # 임베딩
        Hs = encoder(src.edge_index.to(device), src.edge_type.to(device))
        Ht = encoder(tgt.edge_index.to(device), tgt.edge_type.to(device))

        # --- 소스: 양성 엣지 + 도메인 매칭 음성 ---
        pos_all, _ = sample_pos_neg_edges(src.edge_index.to(device), src.num_nodes, device=device)
        if pos_all is not None:
            mpos = filter_edges_by_domain_pairs(pos_all, src.node_domain, keep_src_pairs)
            pos = pos_all[:, mpos]
        else:
            pos = None

        if pos is None or pos.size(1) == 0:
            cls_loss = torch.tensor(0.0, device=device)
            P = 0; N = 0
        else:
            # 양성
            hu_pos, hv_pos = Hs[pos[0]], Hs[pos[1]]
            log_pos = pair_head(hu_pos, hv_pos)
            y_pos = torch.ones(log_pos.size(0), dtype=torch.long, device=device)
            P = y_pos.numel()

            # 음성(도메인 매칭, 비율 기반)
            neg = sample_neg_domain_matched(
                pos, src.node_domain, src.nodes_by_domain,
                k=args.neg_ratio, max_negs=args.max_negs, device=device
            )
            hu_neg, hv_neg = Hs[neg[0]], Hs[neg[1]]
            log_neg = pair_head(hu_neg, hv_neg)
            y_neg = torch.zeros(log_neg.size(0), dtype=torch.long, device=device)
            N = y_neg.numel()

            logits = torch.cat([log_pos, log_neg], dim=0)
            y = torch.cat([y_pos, y_neg], dim=0)

            # 🔸 클래스 가중치 토글
            if getattr(args, "balance_ce", True):
                total = float(P + N) + 1e-12
                w_neg = total / (2.0 * float(N) + 1e-12)
                w_pos = total / (2.0 * float(P) + 1e-12)
                weights = torch.tensor([w_neg, w_pos], device=device, dtype=torch.float)
                cls_loss = F.cross_entropy(logits, y, weight=weights)
            else:
                cls_loss = F.cross_entropy(logits, y)

        # --- 도메인 적대 ---
        ds = domain_head(Hs); dt = domain_head(Ht)
        y_ds = torch.zeros(ds.size(0), dtype=torch.long, device=device)
        y_dt = torch.ones(dt.size(0),  dtype=torch.long, device=device)
        grl_loss = F.cross_entropy(torch.cat([ds, dt], dim=0), torch.cat([y_ds, y_dt], dim=0))

        # --- 타깃 엔트로피 (inter 전용) ---
        Eh_t = tgt.edge_index.size(1)//2
        if Eh_t > 0:
            pos_t = tgt.edge_index[:, :Eh_t].to(device)
            mask_inter = filter_edges_by_domain_pairs(pos_t, tgt.node_domain, keep_tgt_pairs_inter)
            if mask_inter.any():
                idx = torch.nonzero(mask_inter, as_tuple=False).view(-1)
                if idx.numel() > 2048:
                    idx = idx[torch.randperm(idx.numel(), device=device)[:2048]]
            else:
                idx = torch.randint(0, Eh_t, (min(2048, Eh_t),), device=device)
            u_t = pos_t[0, idx]; v_t = pos_t[1, idx]
            pt = F.softmax(pair_head(Ht[u_t], Ht[v_t]), dim=-1).clamp_min(1e-9)
            ent_loss = -(pt * pt.log()).sum(dim=-1).mean()
        else:
            ent_loss = torch.tensor(0.0, device=device)

        # L2(약하게)
        reg = torch.tensor(0.0, device=device)
        for m in [encoder, pair_head]:
            for p in m.parameters():
                if p.requires_grad and p.dim() > 1:
                    reg = reg + 1e-4 * (p**2).mean()

        loss = cls_loss + grl_loss + entw_now * ent_loss + reg
        loss.backward()
        torch.nn.utils.clip_grad_norm_(list(encoder.parameters()) + list(pair_head.parameters()), 5.0)
        optim.step()

        # --- eval (ACC/balACC + AUC + ACC@best + H@10) ---
        encoder.eval(); pair_head.eval()
        with torch.no_grad():
            Hs_eval = encoder(src.edge_index.to(device), src.edge_type.to(device))
            Ht_eval = encoder(tgt.edge_index.to(device), tgt.edge_type.to(device))
            src_metrics = eval_link_metrics(
                Hs_eval, src.edge_index.to(device), pair_head,
                restrict_pairs=keep_src_pairs, node_domain=src.node_domain.to(device),
                sample_limit=args.eval_sample_limit,
                nodes_by_domain=src.nodes_by_domain,
                domain_matched_neg=True, return_best=True
            )
            tgt_metrics = eval_link_metrics(
                Ht_eval, tgt.edge_index.to(device), pair_head,
                restrict_pairs=keep_tgt_pairs_inter, node_domain=tgt.node_domain.to(device),
                sample_limit=args.eval_sample_limit,
                nodes_by_domain=tgt.nodes_by_domain,
                domain_matched_neg=True, return_best=True
            )
            # 랭킹(H@10만)
            q_lim = min(args.rank_sample_queries, 256)
            rank_src = eval_ranking_metrics(Hs_eval, src.edge_index.to(device), pair_head,
                                            src.node_domain.to(device), keep_src_pairs,
                                            src.nodes_by_domain, adj_src, sample_queries=q_lim)
            rank_tgt = eval_ranking_metrics(Ht_eval, tgt.edge_index.to(device), pair_head,
                                            tgt.node_domain.to(device), keep_tgt_pairs_inter,
                                            tgt.nodes_by_domain, adj_tgt, sample_queries=q_lim)

        if ep_global % args.print_every == 0:
            print(f"[{ep_global:03d}] loss={loss.item():.4f} | "
                  f"SRC balACC={src_metrics['bal_acc'].item():.4f} AUC={src_metrics['auc'].item():.4f} "
                  f"ACC={src_metrics['acc'].item():.4f} ACC*={src_metrics['acc_best'].item():.4f}@{src_metrics['thr_best']:.2f} "
                  f"H@10={rank_src['hits@10'].item():.4f} | "
                  f"TGT balACC={tgt_metrics['bal_acc'].item():.4f} AUC={tgt_metrics['auc'].item():.4f} "
                  f"ACC={tgt_metrics['acc'].item():.4f} ACC*={tgt_metrics['acc_best'].item():.4f}@{tgt_metrics['thr_best']:.2f} "
                  f"H@10={rank_tgt['hits@10'].item():.4f} | "
                  f"cls={cls_loss.item():.4f} grl={grl_loss.item():.4f} ent={ent_loss.item():.4f} "
                  f"(λ={lambd:.3f}, P={P}, N={N}, neg_ratio={args.neg_ratio})")

        # early stopping: 타깃 AUC 기준
        tgt_score = tgt_metrics['auc'].item()
        if tgt_score > best_tgt:
            best_tgt = tgt_score; best_src = src_metrics['auc'].item(); best_ep = ep_global
            patience_counter = 0
        else:
            patience_counter += 1
            if patience_counter >= args.patience:
                print(f"⏹ Early stopping at epoch {ep_global} (no improvement for {args.patience}). "
                      f"BEST TGT AUC={best_tgt:.4f} @ {best_ep}")
                stopped_early = True
                break

    return current_epoch, best_ep, best_src, best_tgt, stopped_early

print("✅ Training step ready. use: train_for_epochs(num_epochs=5)")

