import pandas as pd

@torch.no_grad()
def sample_neg_pairs(pos_uv: torch.Tensor,
                     node_domain: torch.Tensor,
                     nodes_by_domain: dict,
                     k: int,
                     device):
    if pos_uv is None or pos_uv.numel() == 0 or k <= 0:
        return None
    pos_uv = pos_uv.to(device=device, dtype=torch.long).contiguous()
    nd = node_domain.to(device=device, dtype=torch.long)
    P = pos_uv.size(1)
    u_rep = pos_uv[0].repeat_interleave(k)
    v_dom = nd[pos_uv[1]].repeat_interleave(k)
    v_neg = torch.empty_like(u_rep, dtype=torch.long, device=device)

    for d in v_dom.unique().tolist():
        d_int = int(d)
        mask = (v_dom == d_int)
        count = int(mask.sum().item())
        pool = nodes_by_domain.get(d_int, None)
        if pool is None or (isinstance(pool, torch.Tensor) and pool.numel() == 0):
            v_neg[mask] = torch.randint(0, int(nd.size(0)), (count,), device=device)
        else:
            pool_dev = pool.to(device=device, dtype=torch.long)
            ridx = torch.randint(0, pool_dev.size(0), (count,), device=device)
            v_neg[mask] = pool_dev[ridx]

    return torch.stack([u_rep, v_neg], dim=0)

class JointHead(nn.Module):
    # 출력 차원: 0 = No_Link, 1..R = 관계 타입
    def __init__(self, dim, hidden, num_rel):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(4*dim, hidden), nn.ReLU(), nn.Dropout(0.1),
            nn.Linear(hidden, num_rel+1)
        )
    def forward(self, hu, hv):
        z = torch.cat([hu, hv, (hu-hv).abs(), hu*hv], dim=-1)
        return self.net(z)

